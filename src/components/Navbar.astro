---
const navLinks = [
  { label: 'Industries', href: '#industries' },
  { label: 'Journey', href: '#journey' },
  { label: 'Projects', href: '#projects' },
  { label: 'Leadership', href: '#leadership' },
  { label: 'Contact', href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2">
      <span class="font-display text-2xl tracking-tight nav-text transition-colors duration-500 text-white">ARMA</span>
      <span class="hidden sm:inline text-xs tracking-[0.2em] uppercase nav-text-sub transition-colors duration-500 text-white/60">Group</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link text-sm tracking-wide transition-colors duration-300 text-white/70 hover:text-white">{link.label}</a>
      ))}
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block w-4 h-0.5 bg-white transition-all duration-300 ml-auto"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
    <div class="px-6 pb-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link text-sm tracking-wide transition-colors duration-300 text-white/70 hover:text-white">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  let scrolled = false;
  let menuOpen = false;

  function updateNav() {
    const isScrolled = window.scrollY > 50;
    if (isScrolled === scrolled) return;
    scrolled = isScrolled;

    if (isScrolled) {
      navbar!.classList.add('bg-white', 'shadow-sm', 'shadow-black/5');
      navbar!.querySelectorAll('.nav-text').forEach(el => {
        el.classList.remove('text-white');
        el.classList.add('text-arma-dark');
      });
      navbar!.querySelectorAll('.nav-text-sub').forEach(el => {
        el.classList.remove('text-white/60');
        el.classList.add('text-arma-dark/50');
      });
      navbar!.querySelectorAll('.nav-link').forEach(el => {
        el.classList.remove('text-white/70', 'hover:text-white');
        el.classList.add('text-arma-dark/60', 'hover:text-arma');
      });
      navbar!.querySelectorAll('.mobile-link').forEach(el => {
        el.classList.remove('text-white/70', 'hover:text-white');
        el.classList.add('text-arma-dark/60', 'hover:text-arma');
      });
      navbar!.querySelectorAll('.hamburger-line').forEach(el => {
        el.classList.remove('bg-white');
        el.classList.add('bg-arma-dark');
      });
    } else {
      navbar!.classList.remove('bg-white', 'shadow-sm', 'shadow-black/5');
      navbar!.querySelectorAll('.nav-text').forEach(el => {
        el.classList.add('text-white');
        el.classList.remove('text-arma-dark');
      });
      navbar!.querySelectorAll('.nav-text-sub').forEach(el => {
        el.classList.add('text-white/60');
        el.classList.remove('text-arma-dark/50');
      });
      navbar!.querySelectorAll('.nav-link').forEach(el => {
        el.classList.add('text-white/70', 'hover:text-white');
        el.classList.remove('text-arma-dark/60', 'hover:text-arma');
      });
      navbar!.querySelectorAll('.mobile-link').forEach(el => {
        el.classList.add('text-white/70', 'hover:text-white');
        el.classList.remove('text-arma-dark/60', 'hover:text-arma');
      });
      navbar!.querySelectorAll('.hamburger-line').forEach(el => {
        el.classList.add('bg-white');
        el.classList.remove('bg-arma-dark');
      });
    }
  }

  toggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
    } else {
      menu!.style.maxHeight = '0';
    }
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menuOpen = false;
      menu!.style.maxHeight = '0';
    });
  });

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
