---
const navLinks = [
  { label: 'Industries', href: '#industries' },
  { label: 'Journey', href: '#journey' },
  { label: 'Projects', href: '#projects' },
  { label: 'Leadership', href: '#leadership' },
  { label: 'Contact', href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group">
      <div class="w-9 h-9 rounded-lg bg-electric/10 border border-electric/20 flex items-center justify-center group-hover:bg-electric/20 transition-all duration-300">
        <svg class="w-4 h-4 text-electric" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </div>
      <div class="flex items-baseline gap-1.5">
        <span class="font-display text-xl font-bold tracking-tight text-white">ARMA</span>
        <span class="text-[10px] tracking-[0.25em] uppercase text-electric/60 font-semibold">Group</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link text-[13px] font-medium tracking-wide px-4 py-2 rounded-lg transition-all duration-300 text-white/50 hover:text-white hover:bg-white/5">{link.label}</a>
      ))}
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="hamburger-line block w-6 h-0.5 bg-white/70 transition-all duration-300"></span>
      <span class="hamburger-line block w-6 h-0.5 bg-white/70 transition-all duration-300"></span>
      <span class="hamburger-line block w-4 h-0.5 bg-electric transition-all duration-300 ml-auto"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out bg-navy-light/95 backdrop-blur-xl">
    <div class="px-6 pb-6 flex flex-col gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link text-sm font-medium tracking-wide py-3 px-4 rounded-lg text-white/60 hover:text-white hover:bg-white/5 transition-all duration-300">{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  let scrolled = false;
  let menuOpen = false;

  function updateNav() {
    const isScrolled = window.scrollY > 50;
    if (isScrolled === scrolled) return;
    scrolled = isScrolled;

    if (isScrolled) {
      navbar!.classList.add('bg-navy/90', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    } else {
      navbar!.classList.remove('bg-navy/90', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    }
  }

  toggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
    } else {
      menu!.style.maxHeight = '0';
    }
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menuOpen = false;
      menu!.style.maxHeight = '0';
    });
  });

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
