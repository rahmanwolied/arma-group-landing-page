---
const navLinks = [
  { label: 'Industries', href: '#industries' },
  { label: 'Journey',    href: '#journey' },
  { label: 'Projects',   href: '#projects' },
  { label: 'Leadership', href: '#leadership' },
  { label: 'Contact',    href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 flex items-center justify-between h-[72px]">

    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5">
      <span class="font-display text-[26px] font-light tracking-tight nav-text text-white transition-colors duration-400">ARMA</span>
      <span class="hidden sm:inline font-mono text-[9px] tracking-[0.3em] uppercase nav-text-sub text-white/45 transition-colors duration-400">Group</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-9">
      {navLinks.map(link => (
        <a href={link.href}
          class="nav-link text-[11px] font-medium tracking-[0.15em] uppercase text-white/55 hover:text-white transition-colors duration-300">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile toggle -->
    <button id="mobile-toggle" class="md:hidden flex flex-col gap-[5px] p-2" aria-label="Toggle menu">
      <span class="hamburger-line block w-6 h-[1.5px] bg-white transition-all duration-300"></span>
      <span class="hamburger-line block w-6 h-[1.5px] bg-white transition-all duration-300"></span>
      <span class="hamburger-line block w-4 h-[1.5px] bg-white transition-all duration-300 ml-auto"></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
    <div class="px-6 pb-6 pt-2 flex flex-col gap-5 border-t border-white/[0.08]">
      {navLinks.map(link => (
        <a href={link.href}
          class="mobile-link text-[11px] font-medium tracking-[0.15em] uppercase text-white/55 hover:text-white transition-colors duration-300">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const navbar   = document.getElementById('navbar')!;
  const toggle   = document.getElementById('mobile-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  let scrolled   = false;
  let menuOpen   = false;

  function updateNav() {
    const isScrolled = window.scrollY > 60;
    if (isScrolled === scrolled) return;
    scrolled = isScrolled;

    if (isScrolled) {
      navbar.style.cssText = 'background:rgba(4,9,6,0.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.05)';
      navbar.querySelectorAll<HTMLElement>('.nav-text').forEach(el  => { el.style.color = '#ffffff'; });
      navbar.querySelectorAll<HTMLElement>('.nav-text-sub').forEach(el => { el.style.color = 'rgba(255,255,255,0.35)'; });
      navbar.querySelectorAll<HTMLElement>('.nav-link').forEach(el  => { el.style.color = 'rgba(255,255,255,0.5)'; });
    } else {
      navbar.style.cssText = '';
      navbar.querySelectorAll<HTMLElement>('.nav-text').forEach(el  => { el.style.color = ''; });
      navbar.querySelectorAll<HTMLElement>('.nav-text-sub').forEach(el => { el.style.color = ''; });
      navbar.querySelectorAll<HTMLElement>('.nav-link').forEach(el  => { el.style.color = ''; });
    }
  }

  toggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    menu.style.maxHeight = menuOpen ? menu.scrollHeight + 'px' : '0';
  });
  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menuOpen = false;
      menu.style.maxHeight = '0';
    });
  });

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
