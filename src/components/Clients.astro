---
const clients = [
  { name: 'BPDB', color: '#e53e3e' },
  { name: 'PGCB', color: '#38a169' },
  { name: 'DPDC', color: '#3182ce' },
  { name: 'DESCO', color: '#805ad5' },
  { name: 'Govt Projects', color: '#dd6b20' },
];
---

<section class="relative py-16 lg:py-20 overflow-hidden">
  <div class="absolute inset-0 bg-navy"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="text-center mb-12 fade-up">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-electric/40"></div>
        <span class="text-electric text-[11px] tracking-[0.3em] uppercase font-bold">Trusted By</span>
        <div class="h-px w-8 bg-electric/40"></div>
      </div>
      <h2 class="font-display text-3xl lg:text-4xl font-bold">Our Clients & Partners</h2>
    </div>

    <!-- Client logos marquee -->
    <div class="relative overflow-hidden fade-up">
      <!-- Fade edges -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-navy to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-navy to-transparent z-10 pointer-events-none"></div>

      <div class="flex animate-marquee w-max">
        {[...clients, ...clients, ...clients].map(client => (
          <div class="flex items-center justify-center mx-8 lg:mx-14 py-4">
            <div class="flex items-center gap-3 opacity-40 hover:opacity-100 transition-all duration-500 group cursor-default">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-white/10 group-hover:border-electric/30 transition-all duration-500" style={`background: ${client.color}15`}>
                <div class="w-3 h-3 rounded-full" style={`background: ${client.color}`}></div>
              </div>
              <span class="text-sm font-bold tracking-wide text-white whitespace-nowrap">{client.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom energy line -->
  <div class="absolute bottom-0 left-0 right-0 section-divider"></div>
</section>
