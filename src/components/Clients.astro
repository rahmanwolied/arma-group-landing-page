---
const clients = [
  { name: 'BPDB',            full: 'Bangladesh Power Development Board' },
  { name: 'PGCB',            full: 'Power Grid Company of Bangladesh' },
  { name: 'DPDC',            full: 'Dhaka Power Distribution Company' },
  { name: 'DESCO',           full: 'Dhaka Electric Supply Company' },
  { name: 'BREB',            full: 'Bangladesh Rural Electrification Board' },
  { name: 'NESCO',           full: 'Northern Electricity Supply Company' },
  { name: 'Govt. Projects',  full: 'Government of Bangladesh' },
];
---

<section class="py-16 lg:py-20 bg-arma-bg border-t border-arma-dark/[0.07]">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-14 fade-up">
      <div>
        <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-arma">Trusted By</span>
        <h2 class="font-display text-[clamp(32px,4.5vw,48px)] font-light mt-1.5 leading-tight">Our Clients & Partners</h2>
      </div>
      <div class="hidden sm:flex items-center gap-3">
        <div class="w-12 h-px bg-arma-dark/15"></div>
        <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-arma-dark/30">{clients.length} Partners</span>
      </div>
    </div>

    <!-- Marquee -->
    <div class="relative overflow-hidden fade-up">
      <!-- Edge fades -->
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-arma-bg to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-arma-bg to-transparent z-10 pointer-events-none"></div>

      <!-- Top border -->
      <div class="border-t border-arma-dark/[0.07] mb-0">
        <div class="flex animate-marquee w-max py-0">
          {[...clients, ...clients].map((client, i) => (
            <div class="flex items-center mx-10 lg:mx-16 py-6 group cursor-default shrink-0">
              <div class="flex items-center gap-3.5 grayscale opacity-30 hover:grayscale-0 hover:opacity-100 transition-all duration-500">
                <!-- Abstract logo mark -->
                <div class="w-8 h-8 flex items-center justify-center border border-arma/20 group-hover:border-arma/50 group-hover:bg-arma/5 transition-all duration-400">
                  <div class="w-2 h-2 bg-arma/40 group-hover:bg-arma transition-colors duration-300"></div>
                </div>
                <div>
                  <div class="font-semibold text-[13px] tracking-wide text-arma-dark whitespace-nowrap">{client.name}</div>
                  <div class="font-mono text-[9px] tracking-[0.15em] text-arma-dark/35 whitespace-nowrap mt-0.5">{client.full}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="border-b border-arma-dark/[0.07]"></div>

    </div>
  </div>
</section>
