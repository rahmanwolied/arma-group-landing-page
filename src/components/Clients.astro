---
const clients = ['BPDB', 'PGCB', 'DPDC', 'DESCO', 'BREB', 'NESCO', 'Govt. Projects'];
---

<section class="py-16 lg:py-20 bg-gray-50/80 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12 fade-up">
      <span class="text-arma text-xs tracking-[0.3em] uppercase font-semibold">Trusted By</span>
      <h2 class="font-display text-3xl lg:text-4xl mt-3">Our Clients & Partners</h2>
    </div>

    <!-- Marquee -->
    <div class="relative overflow-hidden fade-up">
      <!-- Fade edges -->
      <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-gray-50/80 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-gray-50/80 to-transparent z-10 pointer-events-none"></div>

      <div class="flex animate-marquee w-max">
        {[...clients, ...clients].map(client => (
          <div class="flex items-center justify-center mx-8 lg:mx-12 py-4 group cursor-default">
            <div class="flex items-center gap-3 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-500">
              <div class="w-10 h-10 rounded-lg bg-arma/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-arma" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
              </div>
              <span class="text-sm font-semibold tracking-wide text-arma-dark whitespace-nowrap">{client}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
