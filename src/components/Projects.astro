---
const featured = {
  title: 'Transmission Line Projects',
  desc: 'High-voltage transmission lines powering communities across Bangladesh — from 33kV distribution networks to 400kV national grid infrastructure, delivered with precision engineering.',
  image: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=1200&q=90',
  tag: 'Power & Energy',
  stat: '400kV',
  statLabel: 'Max Capacity',
};

const secondary = [
  {
    title: 'Real Estate Developments',
    desc: 'Premium residential complexes and commercial spaces redefining urban living in Dhaka.',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&q=88',
    tag: 'Real Estate',
  },
  {
    title: 'Agricultural Initiatives',
    desc: 'Sustainable farming operations and dairy production feeding the nation with quality produce.',
    image: 'https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=800&q=88',
    tag: 'Agriculture',
  },
];
---

<section id="projects" class="py-24 lg:py-32 bg-arma-bg">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">

    <!-- Heading -->
    <div class="flex items-end justify-between mb-16 fade-up">
      <div>
        <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-arma">Our Work</span>
        <h2 class="font-display text-[clamp(40px,5.5vw,64px)] font-light mt-2 leading-tight">Project Highlights</h2>
      </div>
      <div class="hidden lg:flex items-center gap-3 text-arma-dark/30">
        <div class="w-16 h-px bg-arma-dark/15 line-grow"></div>
        <span class="font-mono text-[9px] tracking-[0.3em] uppercase">Selected Works</span>
      </div>
    </div>

    <!-- Editorial grid: featured + 2 stacked -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-3">

      <!-- Featured: spans 3 columns -->
      <div class="lg:col-span-3 group relative overflow-hidden cursor-pointer min-h-[480px] lg:min-h-[560px] fade-up fade-up-delay-1">
        <!-- Image -->
        <div
          class="absolute inset-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-[1.04]"
          style={`background-image: url('${featured.image}')`}
        ></div>
        <!-- Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-arma-deep/92 via-arma-deep/30 to-arma-deep/10"></div>
        <div class="absolute inset-0 mix-blend-multiply transition-opacity duration-500" style="background: rgba(3,115,41,0.15)"></div>

        <!-- Stat chip top-right -->
        <div class="absolute top-6 right-6 flex flex-col items-end">
          <span class="font-display text-3xl font-light text-white">{featured.stat}</span>
          <span class="font-mono text-[9px] tracking-[0.2em] uppercase text-white/35">{featured.statLabel}</span>
        </div>

        <!-- Content -->
        <div class="relative h-full flex flex-col justify-end p-8 lg:p-10">
          <span class="inline-flex items-center w-fit mb-4 font-mono text-[9px] tracking-[0.25em] uppercase text-arma-accent/80 bg-white/[0.07] backdrop-blur-sm border border-white/10 px-2.5 py-1">
            {featured.tag}
          </span>
          <h3 class="font-display text-[clamp(28px,3.5vw,42px)] font-light text-white leading-tight mb-3">{featured.title}</h3>
          <p class="text-white/45 text-[14px] leading-relaxed max-w-sm font-light">{featured.desc}</p>
          <div class="flex items-center gap-2 mt-6 text-white/35 group-hover:text-arma-accent transition-colors duration-300">
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase font-semibold">Learn More</span>
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </div>

      <!-- Two secondary cards stacked -->
      <div class="lg:col-span-2 flex flex-col gap-3">
        {secondary.map((proj, i) => (
          <div class={`group relative overflow-hidden cursor-pointer flex-1 min-h-[230px] fade-up fade-up-delay-${i + 2}`}>
            <!-- Image -->
            <div
              class="absolute inset-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-[1.06]"
              style={`background-image: url('${proj.image}')`}
            ></div>
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-arma-deep/88 via-arma-deep/35 to-arma-deep/10"></div>
            <div class="absolute inset-0 mix-blend-multiply opacity-70" style="background: rgba(3,115,41,0.12)"></div>

            <!-- Content -->
            <div class="relative h-full flex flex-col justify-end p-6 lg:p-7">
              <span class="inline-flex items-center w-fit mb-2.5 font-mono text-[9px] tracking-[0.22em] uppercase text-arma-accent/75 bg-white/[0.06] backdrop-blur-sm border border-white/10 px-2 py-0.5">
                {proj.tag}
              </span>
              <h3 class="font-display text-[clamp(20px,2.2vw,26px)] font-light text-white leading-tight mb-2">{proj.title}</h3>
              <p class="text-white/40 text-[12px] leading-relaxed max-h-0 overflow-hidden group-hover:max-h-14 transition-all duration-500 font-light">{proj.desc}</p>
              <div class="flex items-center gap-2 mt-3 text-white/30 group-hover:text-arma-accent transition-colors duration-300">
                <span class="font-mono text-[9px] tracking-[0.2em] uppercase">Learn More</span>
                <svg class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
