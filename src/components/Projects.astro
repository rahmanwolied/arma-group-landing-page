---
const projects = [
  {
    title: 'Transmission Line Projects',
    desc: 'High-voltage transmission lines powering communities across Bangladesh. From 33kV to 400kV infrastructure.',
    image: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=800&q=80',
    tag: 'Power & Energy',
  },
  {
    title: 'Real Estate Developments',
    desc: 'Premium residential complexes and commercial spaces redefining urban living in Dhaka.',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&q=80',
    tag: 'Real Estate',
  },
  {
    title: 'Agricultural Initiatives',
    desc: 'Sustainable farming operations and dairy production feeding the nation with quality produce.',
    image: 'https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=800&q=80',
    tag: 'Agriculture',
  },
];
---

<section id="projects" class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-navy via-navy-light to-navy"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section header -->
    <div class="text-center mb-16 fade-up">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-electric/40"></div>
        <span class="text-electric text-[11px] tracking-[0.3em] uppercase font-bold">Our Work</span>
        <div class="h-px w-8 bg-electric/40"></div>
      </div>
      <h2 class="font-display text-4xl lg:text-5xl font-bold">Project Highlights</h2>
    </div>

    <!-- Project cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {projects.map((project, i) => (
        <div class={`group relative rounded-2xl overflow-hidden min-h-[420px] cursor-pointer fade-up fade-up-delay-${i + 1}`}>
          <!-- Image -->
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110" style={`background-image: url('${project.image}')`}></div>

          <!-- Overlay: cinematic dark gradient -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#050d1a] via-[#050d1a]/60 to-transparent group-hover:via-[#050d1a]/40 transition-all duration-700"></div>

          <!-- Electric accent line at top -->
          <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-electric/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Content -->
          <div class="relative h-full flex flex-col justify-end p-7">
            <span class="inline-block text-[10px] tracking-[0.2em] uppercase text-electric bg-electric/10 backdrop-blur-sm px-3 py-1.5 rounded-lg w-fit mb-4 border border-electric/15 font-semibold">{project.tag}</span>
            <h3 class="text-white text-xl font-bold mb-2">{project.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{project.desc}</p>
            <div class="mt-4 flex items-center gap-2 text-electric/60 group-hover:text-electric transition-colors duration-300">
              <span class="text-xs font-bold tracking-wide">Learn More</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>

          <!-- Glow border effect on hover -->
          <div class="absolute inset-0 rounded-2xl border border-electric/0 group-hover:border-electric/20 transition-all duration-500 pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom energy line -->
  <div class="absolute bottom-0 left-0 right-0 section-divider"></div>
</section>
