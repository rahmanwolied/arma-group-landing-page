---
const projects = [
  {
    title: 'Transmission Line Projects',
    desc: 'High-voltage transmission lines powering communities across Bangladesh. From 33kV to 400kV infrastructure.',
    image: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=800&q=80',
    tag: 'Power & Energy',
  },
  {
    title: 'Real Estate Developments',
    desc: 'Premium residential complexes and commercial spaces redefining urban living in Dhaka.',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&q=80',
    tag: 'Real Estate',
  },
  {
    title: 'Agricultural Initiatives',
    desc: 'Sustainable farming operations and dairy production feeding the nation with quality produce.',
    image: 'https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=800&q=80',
    tag: 'Agriculture',
  },
];
---

<section id="projects" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Heading -->
    <div class="text-center mb-16 fade-up">
      <span class="text-arma text-xs tracking-[0.3em] uppercase font-semibold">Our Work</span>
      <h2 class="font-display text-4xl lg:text-5xl mt-3">Project Highlights</h2>
      <div class="w-12 h-0.5 bg-arma mx-auto mt-4"></div>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <div class={`group relative rounded-xl overflow-hidden min-h-[420px] cursor-pointer fade-up fade-up-delay-${i + 1}`}>
          <!-- Image -->
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${project.image}')`}></div>
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10 group-hover:from-black/90 group-hover:via-black/50 transition-all duration-500"></div>

          <!-- Content -->
          <div class="relative h-full flex flex-col justify-end p-8">
            <span class="inline-block text-[10px] tracking-[0.2em] uppercase text-arma bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full w-fit mb-4 border border-white/10">{project.tag}</span>
            <h3 class="text-white text-2xl font-semibold mb-2">{project.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{project.desc}</p>
            <div class="mt-4 flex items-center gap-2 text-white/50 group-hover:text-white transition-colors duration-300">
              <span class="text-xs font-semibold tracking-wide">Learn More</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
