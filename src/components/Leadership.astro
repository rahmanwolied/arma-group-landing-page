---
const leaders = [
  {
    name: 'Chairman',
    title: 'Chairman',
    initials: 'CH',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80',
  },
  {
    name: 'Managing Director',
    title: 'Managing Director',
    initials: 'MD',
    image: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&q=80',
  },
  {
    name: 'Engineering Team',
    title: 'Engineering Team',
    initials: 'ET',
    image: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=400&q=80',
  },
];
---

<section id="leadership" class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-navy to-navy-light"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section header -->
    <div class="text-center mb-16 fade-up">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-electric/40"></div>
        <span class="text-electric text-[11px] tracking-[0.3em] uppercase font-bold">The Team</span>
        <div class="h-px w-8 bg-electric/40"></div>
      </div>
      <h2 class="font-display text-4xl lg:text-5xl font-bold">Our Leadership</h2>
    </div>

    <!-- Leader cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {leaders.map((leader, i) => (
        <div class={`group glass-card rounded-2xl overflow-hidden fade-up fade-up-delay-${i + 1} hover:-translate-y-1`}>
          <!-- Photo -->
          <div class="relative h-56 overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${leader.image}')`}></div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy-light via-transparent to-transparent"></div>
            <!-- Electric border on hover -->
            <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-electric/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
          <!-- Info -->
          <div class="p-5 text-center">
            <h3 class="font-bold text-base text-white">{leader.name}</h3>
            <p class="text-electric/60 text-xs mt-1 font-semibold tracking-wider uppercase">{leader.title}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom energy line -->
  <div class="absolute bottom-0 left-0 right-0 section-divider"></div>
</section>
