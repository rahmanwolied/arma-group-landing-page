---
---

<footer id="contact" class="bg-arma-deep text-white">

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: Brand + Info -->
      <div>
        <!-- Wordmark -->
        <div class="flex items-baseline gap-3 mb-8">
          <span class="font-display text-[40px] font-light tracking-tight">ARMA</span>
          <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-white/30">Group</span>
        </div>

        <!-- Tagline -->
        <p class="font-display text-xl font-light italic text-white/40 mb-6">
          Powering Infrastructure.<br />Building Bangladesh.
        </p>

        <div class="w-16 h-px bg-white/10 mb-8 line-grow"></div>

        <p class="text-white/30 text-[13px] leading-relaxed max-w-[340px] mb-10 font-light">
          A diversified conglomerate delivering excellence since 1985 across power, infrastructure, real estate, agriculture and education.
        </p>

        <!-- Contact details -->
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex items-center justify-center border border-white/08 shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-arma" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            </div>
            <div>
              <p class="text-white/60 text-[13px]">ARMA Complex, Banasree</p>
              <p class="text-white/28 text-[11px] font-mono tracking-wide mt-0.5">Dhaka, Bangladesh</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-8 h-8 flex items-center justify-center border border-white/08 shrink-0">
              <svg class="w-3.5 h-3.5 text-arma" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </div>
            <p class="text-white/60 text-[13px]">+880 2224 406189</p>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-8 h-8 flex items-center justify-center border border-white/08 shrink-0">
              <svg class="w-3.5 h-3.5 text-arma" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <p class="text-white/60 text-[13px]">info@armagroup.com.bd</p>
          </div>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div>
        <div class="mb-8">
          <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-arma-accent/60">Get In Touch</span>
          <h3 class="font-display text-[clamp(28px,3.5vw,38px)] font-light mt-2 text-white">Send a Message</h3>
        </div>

        <form class="space-y-3" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <input
              type="text"
              placeholder="Your Name"
              class="w-full bg-white/[0.04] border border-white/08 hover:border-white/14 px-4 py-3.5 text-[13px] text-white placeholder-white/22 focus:outline-none focus:border-arma/45 transition-all duration-300 font-light"
            />
            <input
              type="email"
              placeholder="Email Address"
              class="w-full bg-white/[0.04] border border-white/08 hover:border-white/14 px-4 py-3.5 text-[13px] text-white placeholder-white/22 focus:outline-none focus:border-arma/45 transition-all duration-300 font-light"
            />
          </div>
          <input
            type="text"
            placeholder="Subject"
            class="w-full bg-white/[0.04] border border-white/08 hover:border-white/14 px-4 py-3.5 text-[13px] text-white placeholder-white/22 focus:outline-none focus:border-arma/45 transition-all duration-300 font-light"
          />
          <textarea
            rows="4"
            placeholder="Your Message"
            class="w-full bg-white/[0.04] border border-white/08 hover:border-white/14 px-4 py-3.5 text-[13px] text-white placeholder-white/22 focus:outline-none focus:border-arma/45 transition-all duration-300 resize-none font-light"
          ></textarea>
          <button
            type="submit"
            class="group inline-flex items-center gap-3 bg-arma hover:bg-arma-accent text-white px-8 py-[14px] text-[11px] font-semibold tracking-[0.18em] uppercase transition-all duration-300 hover:shadow-xl hover:shadow-arma/20 mt-1"
          >
            Send Message
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
          </button>
        </form>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.05]">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/20 font-mono text-[10px] tracking-[0.15em]">&copy; 2025 ARMA Group. All rights reserved.</p>
      <div class="flex items-center gap-8">
        <a href="#" class="text-white/20 hover:text-white/45 transition-colors font-mono text-[10px] tracking-[0.12em]">Privacy Policy</a>
        <a href="#" class="text-white/20 hover:text-white/45 transition-colors font-mono text-[10px] tracking-[0.12em]">Terms of Service</a>
      </div>
    </div>
  </div>

</footer>
