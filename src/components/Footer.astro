---
---

<footer id="contact" class="relative overflow-hidden">
  <!-- Background with city image -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=1600&q=80')] bg-cover bg-bottom opacity-5"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#050a14] via-navy to-navy-light"></div>
  </div>

  <!-- Top energy line -->
  <div class="absolute top-0 left-0 right-0 section-divider"></div>

  <!-- Main footer content -->
  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10 py-20 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: Info -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-9 h-9 rounded-lg bg-electric/10 border border-electric/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-electric" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="font-display text-xl font-bold tracking-tight text-white">ARMA</span>
            <span class="text-[10px] tracking-[0.25em] uppercase text-electric/60 font-semibold">Group</span>
          </div>
        </div>

        <p class="text-slate-dim text-sm leading-relaxed max-w-sm mb-10">
          Powering Infrastructure. Building Bangladesh. A diversified conglomerate delivering excellence since 1985.
        </p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-electric/5 border border-electric/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
            </div>
            <div>
              <p class="text-white/70 text-sm font-medium">ARMA Complex, Banasree</p>
              <p class="text-slate-dim text-xs mt-0.5">Dhaka, Bangladesh</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-electric/5 border border-electric/10 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </div>
            <p class="text-white/70 text-sm font-medium">+880 1234 56/890</p>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl bg-electric/5 border border-electric/10 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <p class="text-white/70 text-sm font-medium">info@armagroup.com.bd</p>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <h3 class="font-display text-2xl font-bold mb-6">Send a Message</h3>
        <form class="space-y-4" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
              type="text"
              placeholder="Your Name"
              class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-5 py-3.5 text-sm text-white placeholder-white/25 focus:outline-none focus:border-electric/40 focus:ring-1 focus:ring-electric/20 transition-all"
            />
            <input
              type="email"
              placeholder="Email Address"
              class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-5 py-3.5 text-sm text-white placeholder-white/25 focus:outline-none focus:border-electric/40 focus:ring-1 focus:ring-electric/20 transition-all"
            />
          </div>
          <input
            type="text"
            placeholder="Subject"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-5 py-3.5 text-sm text-white placeholder-white/25 focus:outline-none focus:border-electric/40 focus:ring-1 focus:ring-electric/20 transition-all"
          />
          <textarea
            rows="4"
            placeholder="Your Message"
            class="w-full bg-white/[0.03] border border-white/10 rounded-xl px-5 py-3.5 text-sm text-white placeholder-white/25 focus:outline-none focus:border-electric/40 focus:ring-1 focus:ring-electric/20 transition-all resize-none"
          ></textarea>
          <button
            type="submit"
            class="group inline-flex items-center gap-2 bg-electric hover:bg-electric-bright text-navy px-8 py-4 rounded-xl text-sm font-bold tracking-wide transition-all duration-300 hover:shadow-[0_0_30px_rgba(14,165,233,0.3)]"
          >
            Send Message
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="relative border-t border-white/5">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/20 text-xs">&copy; 2025 ARMA Group. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-white/20 hover:text-electric/60 transition-colors text-xs">Privacy Policy</a>
        <a href="#" class="text-white/20 hover:text-electric/60 transition-colors text-xs">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
