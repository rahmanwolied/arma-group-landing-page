---
const milestones = [
  { year: '1985', title: 'The Beginning',    desc: 'ARMA Group founded in Dhaka with a vision to build Bangladesh\'s infrastructure.' },
  { year: '1995', title: 'Power Expansion',  desc: 'Expanded into electrical construction and transmission line projects nationwide.' },
  { year: '2005', title: 'Diversification',  desc: 'Entered real estate development and line hardware manufacturing.' },
  { year: '2015', title: 'New Horizons',     desc: 'Launched agriculture and education ventures, becoming a true conglomerate.' },
  { year: '2025', title: 'Future Forward',   desc: 'Expanding into renewable energy and sustainable infrastructure for tomorrow.' },
];
---

<section id="journey" class="py-24 lg:py-32 bg-arma-deep text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">

    <!-- Heading -->
    <div class="mb-20 lg:mb-24 fade-up">
      <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-arma-accent/70">Our History</span>
      <h2 class="font-display text-[clamp(40px,5.5vw,64px)] font-light mt-2 text-white leading-tight">Our Journey</h2>
    </div>

    <!-- Desktop timeline -->
    <div class="hidden md:block relative">
      <!-- Connecting line -->
      <div class="absolute top-[22px] left-0 right-0 h-px bg-white/08 line-grow"></div>

      <div class="grid grid-cols-5 gap-6">
        {milestones.map((m, i) => (
          <div class={`relative group fade-up fade-up-delay-${Math.min(i + 1, 5)}`}>

            <!-- Dot -->
            <div class="relative z-10 w-11 h-11 mx-auto mb-8 flex items-center justify-center border border-white/15 bg-arma-deep group-hover:border-arma/50 group-hover:bg-arma/10 transition-all duration-400">
              <div class="w-2 h-2 bg-arma group-hover:bg-arma-accent transition-colors duration-300"></div>
            </div>

            <!-- Year -->
            <span class="block font-display text-[clamp(28px,3.5vw,40px)] font-light text-arma mb-3">{m.year}</span>

            <!-- Title -->
            <h3 class="font-semibold text-[13px] text-white/80 mb-2 tracking-wide">{m.title}</h3>

            <!-- Desc -->
            <p class="text-white/35 text-[12px] leading-[1.65] font-light">{m.desc}</p>

          </div>
        ))}
      </div>
    </div>

    <!-- Mobile timeline -->
    <div class="md:hidden relative pl-10">
      <!-- Vertical line -->
      <div class="absolute top-0 bottom-0 left-3 w-px bg-white/08"></div>

      <div class="flex flex-col gap-12">
        {milestones.map((m, i) => (
          <div class={`relative fade-up fade-up-delay-${Math.min(i + 1, 4)}`}>
            <!-- Dot -->
            <div class="absolute -left-10 top-1 w-6 h-6 flex items-center justify-center border border-white/15 bg-arma-deep">
              <div class="w-1.5 h-1.5 bg-arma"></div>
            </div>
            <span class="font-display text-[28px] font-light text-arma">{m.year}</span>
            <h3 class="font-semibold text-[13px] text-white/80 mt-1 mb-1.5">{m.title}</h3>
            <p class="text-white/35 text-sm leading-relaxed font-light">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
