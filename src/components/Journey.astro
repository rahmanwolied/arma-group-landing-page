---
const milestones = [
  { year: '1985', title: 'ARMA Electric Founded', desc: 'ARMA Group founded in Dhaka with a vision to build Bangladesh\'s infrastructure.' },
  { year: '2005', title: 'ARMA Agriculture', desc: 'Expanded into agricultural ventures and sustainable farming operations.' },
  { year: '2008', title: 'Purbachal School', desc: 'Launched education sector with school development and community learning.' },
  { year: '2010', title: 'EDNA Holdings', desc: 'Established EDNA Holdings to consolidate group investments and operations.' },
  { year: '2025', title: 'Future Expansion', desc: 'Expanding into renewable energy and sustainable infrastructure for tomorrow.' },
];
---

<section id="journey" class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1600&q=80')] bg-cover bg-center opacity-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy via-navy/95 to-navy"></div>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Section header -->
    <div class="text-center mb-20 fade-up">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-electric/40"></div>
        <span class="text-electric text-[11px] tracking-[0.3em] uppercase font-bold">Our History</span>
        <div class="h-px w-8 bg-electric/40"></div>
      </div>
      <h2 class="font-display text-4xl lg:text-5xl font-bold">Our Journey</h2>
    </div>

    <!-- Desktop Timeline -->
    <div class="hidden md:block relative">
      <!-- Timeline line -->
      <div class="absolute top-[28px] left-0 right-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent"></div>

      <div class="grid grid-cols-5 gap-6">
        {milestones.map((m, i) => (
          <div class={`relative fade-up fade-up-delay-${i + 1}`}>
            <!-- Dot -->
            <div class="relative z-10 mx-auto mb-8">
              <div class="w-14 h-14 rounded-full bg-navy border-2 border-electric/30 flex items-center justify-center mx-auto group hover:border-electric transition-all duration-500">
                <div class="w-3 h-3 rounded-full bg-electric pulse-glow"></div>
              </div>
            </div>
            <!-- Content -->
            <div class="text-center">
              <span class="font-display text-3xl font-bold text-electric counter-glow">{m.year}</span>
              <h3 class="font-semibold text-sm mt-3 mb-2 text-white">{m.title}</h3>
              <p class="text-slate-dim text-xs leading-relaxed">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile Timeline -->
    <div class="md:hidden relative pl-10">
      <!-- Vertical line -->
      <div class="absolute top-0 bottom-0 left-4 w-px bg-gradient-to-b from-electric/30 via-electric/15 to-transparent"></div>

      <div class="flex flex-col gap-12">
        {milestones.map((m, i) => (
          <div class={`relative fade-up fade-up-delay-${Math.min(i + 1, 4)}`}>
            <!-- Dot -->
            <div class="absolute -left-10 top-0 w-8 h-8 rounded-full bg-navy border-2 border-electric/30 flex items-center justify-center">
              <div class="w-2 h-2 rounded-full bg-electric pulse-glow"></div>
            </div>
            <span class="font-display text-2xl font-bold text-electric counter-glow">{m.year}</span>
            <h3 class="font-semibold text-sm mt-1 mb-1 text-white">{m.title}</h3>
            <p class="text-slate-dim text-sm leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom energy line -->
  <div class="absolute bottom-0 left-0 right-0 section-divider"></div>
</section>
